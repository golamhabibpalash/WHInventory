# Top-most EditorConfig file
root = true

# All files
[*]
charset = utf-8
indent_style = space
indent_size = 4
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# C# files
[*.cs]

  #>>> File-scoped namespaces
dotnet_diagnostic.IDE0160.severity = error
dotnet_diagnostic.IDE0161.severity = error
csharp_style_namespace_declarations = file_scoped:error

  #>>> Braces (Allman style)
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true

  #>>> Indentation
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_indent_labels = no_change
csharp_indent_block_contents = true
csharp_indent_braces = false

  #>>> var preferences — always use var when type is clear
csharp_style_var_when_type_is_apparent = true:error
csharp_style_var_for_built_in_types = true:error
csharp_style_var_elsewhere = true:error

  #>>> Expression-bodied members — block bodies preferred
csharp_style_expression_bodied_methods = false:none
csharp_style_expression_bodied_constructors = false:none
csharp_style_expression_bodied_operators = false:none
csharp_style_expression_bodied_properties = true:none
csharp_style_expression_bodied_indexers = true:none
csharp_style_expression_bodied_accessors = true:none
csharp_style_expression_bodied_lambdas = true:none
csharp_style_expression_bodied_local_functions = false:none

  #>>> Null checking — == / != style (no pattern matching)
csharp_style_throw_expression = true:silent
csharp_style_conditional_delegate_call = true:suggestion

  #>>> Modifier order
csharp_preferred_modifier_order = public,private,protected,internal,static,extern,new,virtual,abstract,sealed,override,readonly,unsaid,volatile,async:silent

  #>>> Private fields — _camelCase prefix
dotnet_naming_rule.private_fields_rule.import to IDE
dotnet_naming_rule.private_fields_rule.severity = error
dotnet_naming_rule.private_fields_rule.symbols = private_fields_symbols
dotnet_naming_rule.private_fields_rule.style = private_fields_style

dotnet_naming_symbols.private_fields_symbols.applicable_kinds = field
dotnet_naming_symbols.private_fields_symbols.applicable_accessibilities = private

dotnet_naming_style.private_fields_style.capitalization = camel_case
dotnet_naming_style.private_fields_style.required_prefix = _

  #>>> Private static readonly fields — _camelCase prefix
dotnet_naming_rule.private_static_readonly_rule.import to IDE
dotnet_naming_rule.private_static_readonly_rule.severity = error
dotnet_naming_rule.private_static_readonly_rule.symbols = private_static_readonly_symbols
dotnet_naming_rule.private_static_readonly_rule.style = private_fields_style

dotnet_naming_symbols.private_static_readonly_symbols.applicable_kinds = field
dotnet_naming_symbols.private_static_readonly_symbols.applicable_accessibilities = private
dotnet_naming_symbols.private_static_readonly_symbols.required_modifiers = static,readonly

  #>>> Interfaces — PascalCase with I prefix
dotnet_naming_rule.interface_rule.import to IDE
dotnet_naming_rule.interface_rule.severity = error
dotnet_naming_rule.interface_rule.symbols = interface_symbols
dotnet_naming_rule.interface_rule.style = interface_style

dotnet_naming_symbols.interface_symbols.applicable_kinds = interface
dotnet_naming_style.interface_style.capitalization = pascal_case
dotnet_naming_style.interface_style.required_prefix = I

  #>>> Public members — PascalCase
dotnet_naming_rule.public_members_rule.import to IDE
dotnet_naming_rule.public_members_rule.severity = error
dotnet_naming_rule.public_members_rule.symbols = public_members_symbols
dotnet_naming_rule.public_members_rule.style = pascal_case_style

dotnet_naming_symbols.public_members_symbols.applicable_kinds = method,property,event,delegate,class,struct,enum
dotnet_naming_symbols.public_members_symbols.applicable_accessibilities = public,internal

dotnet_naming_style.pascal_case_style.capitalization = pascal_case

  #>>> Async methods must end with Async
dotnet_naming_rule.async_methods_rule.import to IDE
dotnet_naming_rule.async_methods_rule.severity = error
dotnet_naming_rule.async_methods_rule.symbols = async_methods_symbols
dotnet_naming_rule.async_methods_rule.style = async_methods_style

dotnet_naming_symbols.async_methods_symbols.applicable_kinds = method
dotnet_naming_symbols.async_methods_symbols.required_modifiers = async

dotnet_naming_style.async_methods_style.capitalization = pascal_case
dotnet_naming_style.async_methods_style.required_suffix = Async

  #>>> readonly fields
dotnet_style_readonly_field = true:warning

  #>>> Modifier preferences
csharp_prefer_static_local_function = true:warning
dotnet_style_require_accessibility_modifiers = for_non_interface_members:error

  #>>> Language features
csharp_style_prefer_null_check_over_type_check = false:suggestion
csharp_style_pattern_local_over_anonymous_function = false:silent
csharp_style_prefer_primary_constructors = false:error
csharp_style_prefer_record_struct = false:none
csharp_style_prefer_parameter_null_checking = false:none

  #>>> Using directives
dotnet_sort_system_directives_first = true
csharp_using_directive_placement = outside_namespace:error

  #>>> Unused usings
dotnet_diagnostic.IDE0005.severity = error

  #>>> Implicit type for new expressions
csharp_style_implicit_object_creation_when_type_is_apparent = true:silent

  #>>> Code quality
dotnet_style_prefer_auto_properties = true:silent
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_prefer_is_null_check_over_reference_equals_method = true:suggestion
dotnet_style_prefer_conditional_expression_delegate_call = true:silent
csharp_style_prefer_simple_default_expression = true:suggestion

# XML config files
[*.{csproj,xml,config,nuspec,props,targets}]
indent_size = 2

# JSON files
[*.{json,jsonc}]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false

# Shell scripts
[*.{sh,bash,zsh}]
indent_size = 2
