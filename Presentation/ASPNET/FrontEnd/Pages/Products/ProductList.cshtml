@page
@{
    ViewData["Title"] = "Product List";
}

<div id="app" v-cloak>
    <div class="row">
        <div class="col-12">
            <div class="grid-container">
                <div ref="mainGridRef" id="MainGrid"></div>
            </div>
        </div>
    </div>

    <div class="modal fade" ref="mainModalRef" id="MainModal" aria-hidden="true" tabindex="-1" data-bs-focus="false" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">{{ state.mainTitle }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" v-model="state.id" id="Id" name="Id" />
                    <form id="MainForm">
                        <div class="row">
                            <div class="col-md-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h5><i class="fas fa-info-circle me-2 text-primary"></i>Main Info</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row mb-2">
                                            <div class="col-md-6">
                                                <label for="Name">Name</label>
                                                <input ref="nameRef" v-model="state.name">
                                                <label class="text-danger">{{ state.errors.name }}</label>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="Number">Number</label>
                                                <input ref="numberRef" v-model="state.number" readonly>
                                            </div>
                                        </div>
                                        <div class="row mb-2">
                                            <div class="col-md-6">
                                                <label for="UnitPrice">Unit Price</label>
                                                <input ref="unitPriceRef" v-model="state.unitPrice">
                                                <label class="text-danger">{{ state.errors.unitPrice }}</label>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="UnitMeasureId">Unit Measure</label>
                                                <div class="d-flex align-items-center gap-2">
                                                    <div ref="unitMeasureIdRef" class="flex-grow-1"></div>
                                                    <button type="button"
                                                            class="btn btn-sm btn-outline-warning flex-shrink-0"
                                                            v-on:click="handler.openUnitMeasureQuickCreate"
                                                            v-bind:disabled="state.deleteMode"
                                                            title="Quick-create a new unit measure">
                                                        <i class="fas fa-plus me-1"></i>New
                                                    </button>
                                                </div>
                                                <label class="text-danger">{{ state.errors.unitMeasureId }}</label>
                                            </div>
                                        </div>
                                        <div class="row mb-2">
                                            <div class="col-md-6">
                                                <label for="ProductGroupId">Product Group</label>
                                                <div class="d-flex align-items-center gap-2">
                                                    <div ref="productGroupIdRef" class="flex-grow-1"></div>
                                                    <button type="button"
                                                            class="btn btn-sm btn-outline-success flex-shrink-0"
                                                            v-on:click="handler.openProductGroupQuickCreate"
                                                            v-bind:disabled="state.deleteMode"
                                                            title="Quick-create a new product group">
                                                        <i class="fas fa-plus me-1"></i>New
                                                    </button>
                                                </div>
                                                <label class="text-danger">{{ state.errors.productGroupId }}</label>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="BrandId">Brand</label>
                                                <div class="d-flex align-items-center gap-2">
                                                    <div ref="brandIdRef" class="flex-grow-1"></div>
                                                    <button type="button"
                                                            class="btn btn-sm btn-outline-info flex-shrink-0"
                                                            v-on:click="handler.openBrandQuickCreate"
                                                            v-bind:disabled="state.deleteMode"
                                                            title="Quick-create a new brand">
                                                        <i class="fas fa-plus me-1"></i>New
                                                    </button>
                                                </div>
                                                <label class="text-danger">{{ state.errors.brandId }}</label>
                                            </div>
                                        </div>
                                        <div class="row mb-2">
                                            <div class="col-md-6">
                                                <div class="form-check mt-1">
                                                    <input v-model="state.physical" id="Physical" name="Physical" type="checkbox" class="form-check-input">
                                                    <label for="Physical" class="form-check-label">Is Physical Product?</label>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row mb-2">
                                            <div class="col-12">
                                                <label for="Description">Description</label>
                                                <textarea v-model="state.description" id="Description" name="Description" class="form-control" rows="3"></textarea>
                                            </div>
                                        </div>
                                        <div class="row mb-2">
                                            <div class="col-md-5 text-center mb-3">
                                                <label class="d-block text-start">Product Image</label>
                                                <img v-if="state.imagePreviewUrl"
                                                     :src="state.imagePreviewUrl"
                                                     alt="Product Image"
                                                     style="max-height:140px; max-width:100%; object-fit:contain; border:1px solid #dee2e6; border-radius:6px; padding:8px;" />
                                                <div v-else class="text-muted border rounded" style="height:140px;display:flex;flex-direction:column;align-items:center;justify-content:center;">
                                                    <i class="fas fa-box fa-3x mb-2"></i>
                                                    <span>Default product image</span>
                                                </div>
                                            </div>
                                            <div class="col-md-7">
                                                <label>Upload Image</label>
                                                <div ref="imageUploadRef" id="ImageUpload" class="dropzone"></div>
                                                <small class="text-muted">PNG or JPG only, maximum 1 MB.</small>
                                                <label class="text-danger d-block">{{ state.errors.image }}</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row mt-2" v-if="!state.deleteMode && state.id">
                            <div class="col-md-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h5><i class="fas fa-paperclip me-2 text-secondary"></i>Attachments</h5>
                                    </div>
                                    <div class="card-body">
                                        <div ref="docUploadRef" id="DocUpload" class="dropzone mb-2"></div>
                                        <small class="text-muted">PDF, Word, Excel, PowerPoint — max 25 MB each. Multiple files allowed.</small>
                                        <label class="text-danger d-block mt-1">{{ state.errors.documents }}</label>
                                        <div class="mt-3" v-if="state.documents.length">
                                            <table class="table table-sm table-hover">
                                                <thead>
                                                    <tr>
                                                        <th>File Name</th>
                                                        <th>Type</th>
                                                        <th>Size</th>
                                                        <th></th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr v-for="doc in state.documents" :key="doc.id">
                                                        <td>
                                                            <a :href="'api/FileDocument/GetDocument?documentName=' + doc.generatedName" target="_blank" class="text-decoration-none">
                                                                <i class="fas fa-file me-1"></i>{{ doc.originalName }}
                                                            </a>
                                                        </td>
                                                        <td><span class="badge bg-secondary">{{ (doc.extension || '').toUpperCase() }}</span></td>
                                                        <td>{{ handler.formatFileSize(doc.fileSize) }}</td>
                                                        <td class="text-end">
                                                            <button type="button" class="btn btn-sm btn-outline-danger" v-on:click="handler.deleteDocument(doc.id)" title="Remove attachment">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                        <div v-else class="text-muted small mt-2"><i class="fas fa-info-circle me-1"></i>No attachments yet.</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><i class="fas fa-times me-1"></i>Close</button>
                    <button type="button"
                            id="MainSaveButton"
                            class="btn"
                            v-bind:class="state.deleteMode ? 'btn-danger' : 'btn-primary'"
                            v-on:click="handler.handleSubmit"
                            v-bind:disabled="state.isSubmitting">
                        <span class="spinner-border spinner-border-sm me-2" v-if="state.isSubmitting" role="status" aria-hidden="true"></span>
                        <i v-if="!state.isSubmitting" v-bind:class="state.deleteMode ? 'fas fa-trash me-1' : 'fas fa-save me-1'"></i><span v-if="!state.isSubmitting">{{ state.deleteMode ? 'Delete' : 'Save' }}</span>
                        <span v-else>{{ state.deleteMode ? 'Deleting...' : 'Saving...' }}</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Unit Measure Quick Create Modal -->
    <div class="modal fade" ref="unitMeasureQuickModalRef" id="UnitMeasureQuickModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-md">
            <div class="modal-content">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title"><i class="fas fa-ruler-combined me-2"></i>Quick Create Unit Measure</h5>
                    <button type="button" class="btn-close" v-on:click="handler.closeUnitMeasureQuickCreate" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3"><i class="fas fa-info-circle me-1"></i>Fill in the required fields. The new unit measure will be automatically selected after creation.</p>
                    <div class="row mb-2">
                        <div class="col-md-12">
                            <label>Name <span class="text-danger">*</span></label>
                            <input v-model="state.unitMeasureQuickName" type="text" class="form-control" placeholder="e.g. Kg, Pcs, Ltr" />
                            <span class="text-danger small" v-text="state.unitMeasureQuickErrors.name"></span>
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-12">
                            <label>Description</label>
                            <textarea v-model="state.unitMeasureQuickDescription" class="form-control" rows="2" placeholder="Optional"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" v-on:click="handler.closeUnitMeasureQuickCreate"><i class="fas fa-times me-1"></i>Cancel</button>
                    <button type="button" class="btn btn-warning text-dark" v-on:click="handler.submitUnitMeasureQuickCreate" v-bind:disabled="state.unitMeasureQuickIsSubmitting">
                        <span class="spinner-border spinner-border-sm me-1" v-if="state.unitMeasureQuickIsSubmitting"></span>
                        <i class="fas fa-ruler-combined me-1" v-else></i>
                        {{ state.unitMeasureQuickIsSubmitting ? 'Creating...' : 'Create & Select' }}
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Product Group Quick Create Modal -->
    <div class="modal fade" ref="productGroupQuickModalRef" id="ProductGroupQuickModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-md">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="fas fa-layer-group me-2"></i>Quick Create Product Group</h5>
                    <button type="button" class="btn-close btn-close-white" v-on:click="handler.closeProductGroupQuickCreate" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3"><i class="fas fa-info-circle me-1"></i>Fill in the required fields. The new group will be automatically selected after creation.</p>
                    <div class="row mb-2">
                        <div class="col-md-6">
                            <label>Name <span class="text-danger">*</span></label>
                            <input v-model="state.productGroupQuickName" type="text" class="form-control" placeholder="Product group name" />
                            <span class="text-danger small">{{ state.productGroupQuickErrors.name }}</span>
                        </div>
                        <div class="col-md-6">
                            <label>Parent Group</label>
                            <div ref="productGroupQuickParentIdRef"></div>
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-12">
                            <label>Description</label>
                            <textarea v-model="state.productGroupQuickDescription" class="form-control" rows="2" placeholder="Optional"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" v-on:click="handler.closeProductGroupQuickCreate">
                        <i class="fas fa-times me-1"></i>Cancel
                    </button>
                    <button type="button" class="btn btn-success"
                            v-on:click="handler.submitProductGroupQuickCreate"
                            v-bind:disabled="state.productGroupQuickIsSubmitting">
                        <span class="spinner-border spinner-border-sm me-1" v-if="state.productGroupQuickIsSubmitting"></span>
                        <i class="fas fa-layer-group me-1" v-else></i>
                        {{ state.productGroupQuickIsSubmitting ? 'Creating...' : 'Create & Select' }}
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Brand Quick Create Modal -->
    <div class="modal fade" ref="brandQuickModalRef" id="BrandQuickModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-md">
            <div class="modal-content">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title"><i class="fas fa-trademark me-2"></i>Quick Create Brand</h5>
                    <button type="button" class="btn-close btn-close-white" v-on:click="handler.closeBrandQuickCreate" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3"><i class="fas fa-info-circle me-1"></i>Fill in the required fields. The new brand will be automatically selected after creation.</p>
                    <div class="row mb-2">
                        <div class="col-md-12">
                            <label>Name <span class="text-danger">*</span></label>
                            <input v-model="state.brandQuickName" type="text" class="form-control" placeholder="Brand name" />
                            <span class="text-danger small">{{ state.brandQuickErrors.name }}</span>
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-12">
                            <label>Description</label>
                            <textarea v-model="state.brandQuickDescription" class="form-control" rows="2" placeholder="Optional"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" v-on:click="handler.closeBrandQuickCreate">
                        <i class="fas fa-times me-1"></i>Cancel
                    </button>
                    <button type="button" class="btn btn-info text-white"
                            v-on:click="handler.submitBrandQuickCreate"
                            v-bind:disabled="state.brandQuickIsSubmitting">
                        <span class="spinner-border spinner-border-sm me-1" v-if="state.brandQuickIsSubmitting"></span>
                        <i class="fas fa-trademark me-1" v-else></i>
                        {{ state.brandQuickIsSubmitting ? 'Creating...' : 'Create & Select' }}
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/FrontEnd/Pages/Products/ProductList.cshtml.js"></script>
}