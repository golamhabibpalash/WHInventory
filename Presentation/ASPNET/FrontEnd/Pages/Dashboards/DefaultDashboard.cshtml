@page
@{
    ViewData["Title"] = "Default Dashboard";
}

@section styles {
<style>
    /* ── Strip form-card border on this page ─────────────── */
    #formcard { border: none; background: transparent; }

    /* ── Page header ─────────────────────────────────────── */
    .db-header {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 4px 16px rgba(0,0,0,.05);
        padding: 1.35rem 1.75rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }
    .db-header-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0 0 .18rem;
    }
    .db-header-sub {
        font-size: .8rem;
        color: #64748b;
        margin: 0;
    }
    .db-header-date {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .8rem;
        font-weight: 500;
        color: #475569;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: .5rem 1rem;
        white-space: nowrap;
        flex-shrink: 0;
    }
    .db-header-date i { color: #1b84ff; font-size: .78rem; }

    /* ── Section labels ──────────────────────────────────── */
    .db-section {
        display: flex;
        align-items: center;
        gap: .6rem;
    }
    .db-section-icon {
        width: 28px;
        height: 28px;
        border-radius: 7px;
        background: #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #64748b;
        font-size: .72rem;
        flex-shrink: 0;
    }
    .db-section-text {
        font-size: .72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .1em;
        color: #64748b;
        white-space: nowrap;
    }
    .db-section-line {
        flex: 1;
        height: 1px;
        background: #e2e8f0;
    }

    /* ── KPI card link wrapper ───────────────────────────── */
    .kpi-link {
        display: block;
        height: 100%;
        text-decoration: none;
        color: inherit;
    }
    .kpi-link:hover, .kpi-link:focus { text-decoration: none; color: inherit; }

    /* ── KPI card ────────────────────────────────────────── */
    .kpi-card {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 4px 16px rgba(0,0,0,.05);
        overflow: hidden;
        height: 100%;
        position: relative;
        transition: box-shadow .22s ease, transform .22s ease;
        cursor: pointer;
    }
    .kpi-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--kc, #1b84ff) 0%, var(--kc-lite, rgba(27,132,255,.3)) 100%);
        border-radius: 14px 14px 0 0;
    }
    .kpi-card:hover {
        box-shadow: 0 10px 32px rgba(0,0,0,.12);
        transform: translateY(-3px);
    }
    .kpi-card:active { transform: translateY(-1px); }

    /* ── KPI card body ───────────────────────────────────── */
    .kpi-body {
        padding: 1.35rem 1.4rem 1.2rem;
        display: flex;
        flex-direction: column;
        gap: .75rem;
    }
    .kpi-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .5rem;
    }
    .kpi-label {
        font-size: .67rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .09em;
        color: #64748b;
    }
    .kpi-tag {
        font-size: .62rem;
        font-weight: 600;
        letter-spacing: .04em;
        padding: .18rem .55rem;
        border-radius: 20px;
        white-space: nowrap;
        flex-shrink: 0;
    }
    .kpi-mid {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
    }
    .kpi-value {
        font-size: 2.35rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1;
        letter-spacing: -.04em;
    }
    .kpi-icon {
        width: 64px;
        height: 64px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        flex-shrink: 0;
        transition: transform .22s ease, box-shadow .22s ease;
    }
    .kpi-card:hover .kpi-icon {
        transform: scale(1.1) rotate(-4deg);
        box-shadow: 0 6px 18px rgba(0,0,0,.13);
    }
    .kpi-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: .7rem;
        border-top: 1px solid #f1f5f9;
    }
    .kpi-desc {
        font-size: .71rem;
        color: #94a3b8;
    }
    .kpi-arrow {
        font-size: .72rem;
        color: var(--kc, #1b84ff);
        opacity: 0;
        transform: translateX(-6px);
        transition: opacity .2s ease, transform .2s ease;
    }
    .kpi-card:hover .kpi-arrow {
        opacity: 1;
        transform: translateX(0);
    }

    /* ── Dashboard panels (charts / grids) ──────────────── */
    .dash-panel {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 4px 16px rgba(0,0,0,.05);
        padding: 1.4rem 1.5rem 1.25rem;
        height: 100%;
    }
    .dash-ph {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid #f1f5f9;
        margin-bottom: 1.25rem;
    }
    .dash-ph-left {
        display: flex;
        align-items: center;
        gap: .55rem;
    }
    .dash-ph-bar {
        width: 3px;
        height: 16px;
        border-radius: 3px;
        background: var(--ph-color, #1b84ff);
        flex-shrink: 0;
    }
    .dash-ph-title {
        font-size: .875rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
    }
    .dash-ph-link {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        font-size: .75rem;
        color: #1b84ff;
        font-weight: 500;
        text-decoration: none;
        white-space: nowrap;
        border: 1px solid rgba(27,132,255,.2);
        border-radius: 6px;
        padding: .25rem .65rem;
        transition: background .15s;
    }
    .dash-ph-link:hover {
        background: rgba(27,132,255,.06);
        color: #1b84ff;
        text-decoration: none;
    }
</style>
}

