<!-- Google Web Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500&family=Roboto:wght@500;700;900&display=swap" rel="stylesheet">

<!-- Icon Font Stylesheet -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

<style>

    .lock-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #0c0e1a 0%, #141830 40%, #1a1f3a 70%, #0f1228 100%);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        flex-direction: column;
        overflow: hidden;
    }

    .lock-bg-shapes {
        position: absolute;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
    }

    .lock-shape {
        position: absolute;
        border-radius: 50%;
        opacity: 0.15;
    }

    .lock-shape-1 {
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, #4f6ef7 0%, transparent 70%);
        top: -200px;
        right: -150px;
        animation: lockFloat 8s ease-in-out infinite;
    }

    .lock-shape-2 {
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, #7c3aed 0%, transparent 70%);
        bottom: -100px;
        left: -100px;
        animation: lockFloat 10s ease-in-out infinite reverse;
    }

    .lock-shape-3 {
        width: 250px;
        height: 250px;
        background: radial-gradient(circle, #f59e0b 0%, transparent 70%);
        top: 20%;
        left: 10%;
        animation: lockFloat 12s ease-in-out infinite 2s;
    }

    .lock-shape-4 {
        width: 180px;
        height: 180px;
        background: radial-gradient(circle, #10b981 0%, transparent 70%);
        bottom: 25%;
        right: 15%;
        animation: lockFloat 9s ease-in-out infinite 1s;
    }

    .lock-shape-5 {
        width: 100px;
        height: 100px;
        border: 2px solid rgba(255, 255, 255, 0.05);
        top: 60%;
        left: 50%;
        animation: lockPulse 6s ease-in-out infinite;
    }

    @@keyframes lockFloat {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(30px, -30px) scale(1.05); }
        66% { transform: translate(-20px, 20px) scale(0.95); }
    }

    @@keyframes lockPulse {
        0%, 100% { transform: scale(1); opacity: 0.15; }
        50% { transform: scale(1.3); opacity: 0.25; }
    }

    .lock-content {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 2rem;
        max-width: 520px;
    }

    .lock-brand {
        margin-bottom: 1.5rem;
    }

    .lock-logo {
        height: 72px;
        width: auto;
        object-fit: contain;
        filter: drop-shadow(0 0 20px rgba(79, 110, 247, 0.3));
    }

    .lock-brand-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #4f6ef7, #7c3aed);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        box-shadow: 0 8px 32px rgba(79, 110, 247, 0.3);
    }

    .lock-brand-icon i {
        font-size: 2.2rem;
        color: #fff;
    }

    .lock-title {
        color: #fff;
        font-size: 2.8rem;
        font-weight: 800;
        font-family: 'Roboto', sans-serif;
        margin: 0 0 0.5rem;
        letter-spacing: -0.02em;
        text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
    }

    .lock-subtitle {
        color: rgba(255, 255, 255, 0.5);
        font-size: 1rem;
        font-weight: 400;
        margin: 0 0 1.5rem;
        letter-spacing: 0.05em;
    }

    .lock-divider {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 2rem;
        width: 180px;
    }

    .lock-divider-line {
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.15), transparent);
    }

    .lock-divider-icon {
        color: rgba(79, 110, 247, 0.6);
        font-size: 0.4rem;
        animation: lockPulse 3s ease-in-out infinite;
    }

    .lock-login-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.9rem 2.2rem;
        background: linear-gradient(135deg, #4f6ef7, #6d4aff);
        color: #fff;
        border-radius: 50px;
        font-size: 0.95rem;
        font-weight: 600;
        text-decoration: none;
        box-shadow: 0 4px 24px rgba(79, 110, 247, 0.35);
        transition: all 0.3s ease;
        cursor: pointer;
        border: none;
        margin-bottom: 2.5rem;
    }

    .lock-login-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(79, 110, 247, 0.5);
        color: #fff;
        text-decoration: none;
    }

    .lock-login-btn:active {
        transform: translateY(0);
    }

    .lock-btn-icon {
        transition: transform 0.3s ease;
        display: inline-flex;
    }

    .lock-login-btn:hover .lock-btn-icon {
        transform: translateX(4px);
    }

    .lock-footer {
        color: rgba(255, 255, 255, 0.25);
        font-size: 0.78rem;
        margin: 0;
        letter-spacing: 0.02em;
    }






</style>