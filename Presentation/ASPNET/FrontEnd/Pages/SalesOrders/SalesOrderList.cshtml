@page
@{
    ViewData["Title"] = "Sales Order List";
}

<div id="app" v-cloak>
    <div class="row">
        <div class="col-12">
            <div class="grid-container">
                <div ref="mainGridRef" id="MainGrid"></div>
            </div>
        </div>
    </div>

    <div class="modal fade" ref="mainModalRef" id="MainModal" aria-hidden="true" tabindex="-1" data-bs-focus="false" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">{{ state.mainTitle }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" v-model="state.id" id="Id" name="Id" />
                    <form id="MainForm">
                        <div class="row">
                            <div class="col-md-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h5><i class="fas fa-info-circle me-2 text-primary"></i>Main Info</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row mb-2">
                                            <div class="col-md-6">
                                                <label for="OrderDate">Order Date</label>
                                                <input ref="orderDateRef" />
                                                <label class="text-danger">{{ state.errors.orderDate }}</label>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="Number">Number</label>
                                                <input ref="numberRef" v-model="state.number" readonly>
                                            </div>
                                        </div>
                                        <div class="row mb-2">
                                            <div class="col-md-6">
                                                <label for="CustomerId">Customer</label>
                                                <div class="d-flex align-items-center gap-2">
                                                    <div ref="customerIdRef" class="flex-grow-1"></div>
                                                    <button type="button"
                                                            class="btn btn-sm btn-outline-primary flex-shrink-0"
                                                            v-on:click="handler.openCustomerQuickCreate"
                                                            v-bind:disabled="state.deleteMode"
                                                            title="Quick-create a new customer">
                                                        <i class="fas fa-plus me-1"></i>New
                                                    </button>
                                                </div>
                                                <label class="text-danger">{{ state.errors.customerId }}</label>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="TaxId">Tax</label>
                                                <div ref="taxIdRef"></div>
                                                <label class="text-danger">{{ state.errors.taxId }}</label>
                                            </div>
                                        </div>
                                        <div class="row mb-2">
                                            <div class="col-md-6">
                                                <label for="OrderStatus">Order Status</label>
                                                <div ref="orderStatusRef"></div>
                                                <label class="text-danger">{{ state.errors.orderStatus }}</label>
                                            </div>
                                        </div>
                                        <div class="row mb-2">
                                            <div class="col-md-12">
                                                <label for="Description">Description</label>
                                                <textarea class="form-control" rows="3" v-model="state.description"></textarea>
                                                <label class="text-danger">{{ state.errors.description }}</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                    <div id="ComplexDiv" :style="{ display: state.showComplexDiv ? 'block' : 'none' }">
                        <div class="row mt-3">
                            <div class="col-md-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h5><i class="fas fa-list-ul me-2 text-primary"></i>Sales Order Item</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="grid-container">
                                                    <div ref="secondaryGridRef" id="SecondaryGrid"></div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row mt-4">
                            <div class="col-md-12">
                                <div class="card shadow-sm">
                                    <div class="card-header text-white">
                                        <h5 class="mb-0"><i class="fas fa-receipt me-2 text-success"></i>Payment Summary</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row justify-content-end">
                                            <div class="col-md-6">
                                                <div class="d-flex justify-content-between py-2 border-bottom">
                                                    <span class="fw-bold">Subtotal</span>
                                                    <span id="SubTotalAmount">{{ state.subTotalAmount }}</span>
                                                </div>
                                                <div class="d-flex justify-content-between py-2 border-bottom">
                                                    <span class="fw-bold">Tax</span>
                                                    <span id="TaxAmount">{{ state.taxAmount }}</span>
                                                </div>
                                                <div class="d-flex justify-content-between py-2">
                                                    <span class="fw-bold">Total Amount</span>
                                                    <span id="TotalAmount" class="fw-bold text-success">{{ state.totalAmount }}</span>
                                                </div>
                                                <div class="py-2 border-top mt-1" v-if="state.amountInWords">
                                                    <div class="text-muted small fw-bold">Amount in Words</div>
                                                    <div id="AmountInWords" class="fst-italic text-dark small">{{ state.amountInWords }}</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><i class="fas fa-times me-1"></i>Close</button>
                    <button type="button"
                            id="MainSaveButton"
                            class="btn"
                            v-bind:class="state.deleteMode ? 'btn-danger' : 'btn-primary'"
                            v-on:click="handler.handleSubmit"
                            v-bind:disabled="state.isSubmitting">
                        <span class="spinner-border spinner-border-sm me-2" v-if="state.isSubmitting" role="status" aria-hidden="true"></span>
                        <i v-if="!state.isSubmitting" v-bind:class="state.deleteMode ? 'fas fa-trash me-1' : 'fas fa-save me-1'"></i><span v-if="!state.isSubmitting">{{ state.deleteMode ? 'Delete' : 'Save' }}</span>
                        <span v-else>{{ state.deleteMode ? 'Deleting...' : 'Saving...' }}</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Customer Quick Create Modal -->
    <div class="modal fade" ref="customerQuickModalRef" id="CustomerQuickModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-user-plus me-2"></i>Quick Create Customer</h5>
                    <button type="button" class="btn-close" v-on:click="handler.closeCustomerQuickCreate" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3"><i class="fas fa-info-circle me-1"></i>Fill in the required fields. The new customer will be automatically selected after creation.</p>
                    <div class="card mb-3">
                        <div class="card-header"><h6 class="mb-0"><i class="fas fa-info-circle me-2 text-primary"></i>Basic Info</h6></div>
                        <div class="card-body">
                            <div class="row mb-2">
                                <div class="col-md-6">
                                    <label>Name <span class="text-danger">*</span></label>
                                    <input v-model="state.customerQuickName" type="text" class="form-control" placeholder="Customer name" />
                                    <span class="text-danger small">{{ state.customerQuickErrors.name }}</span>
                                </div>
                                <div class="col-md-6">
                                    <label>Description</label>
                                    <input v-model="state.customerQuickDescription" type="text" class="form-control" placeholder="Optional" />
                                </div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-md-6">
                                    <label>Customer Group <span class="text-danger">*</span></label>
                                    <div class="d-flex align-items-center gap-2">
                                        <div ref="customerQuickGroupIdRef" class="flex-grow-1"></div>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-success flex-shrink-0"
                                                v-on:click="handler.openCustomerGroupQuickCreate"
                                                title="Quick-create a new customer group">
                                            <i class="fas fa-plus me-1"></i>New
                                        </button>
                                    </div>
                                    <span class="text-danger small">{{ state.customerQuickErrors.customerGroupId }}</span>
                                </div>
                                <div class="col-md-6">
                                    <label>Customer Category <span class="text-danger">*</span></label>
                                    <div class="d-flex align-items-center gap-2">
                                        <div ref="customerQuickCategoryIdRef" class="flex-grow-1"></div>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-warning flex-shrink-0"
                                                v-on:click="handler.openCustomerCategoryQuickCreate"
                                                title="Quick-create a new customer category">
                                            <i class="fas fa-plus me-1"></i>New
                                        </button>
                                    </div>
                                    <span class="text-danger small">{{ state.customerQuickErrors.customerCategoryId }}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card mb-3">
                        <div class="card-header"><h6 class="mb-0"><i class="fas fa-map-marker-alt me-2 text-primary"></i>Address</h6></div>
                        <div class="card-body">
                            <div class="row mb-2">
                                <div class="col-md-12">
                                    <label>Street <span class="text-danger">*</span></label>
                                    <input v-model="state.customerQuickStreet" type="text" class="form-control" placeholder="Street address" />
                                    <span class="text-danger small">{{ state.customerQuickErrors.street }}</span>
                                </div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-md-4">
                                    <label>City <span class="text-danger">*</span></label>
                                    <input v-model="state.customerQuickCity" type="text" class="form-control" placeholder="City" />
                                    <span class="text-danger small">{{ state.customerQuickErrors.city }}</span>
                                </div>
                                <div class="col-md-4">
                                    <label>State / Province <span class="text-danger">*</span></label>
                                    <input v-model="state.customerQuickAddrState" type="text" class="form-control" placeholder="State / Province" />
                                    <span class="text-danger small">{{ state.customerQuickErrors.addrState }}</span>
                                </div>
                                <div class="col-md-4">
                                    <label>Zip Code <span class="text-danger">*</span></label>
                                    <input v-model="state.customerQuickZipCode" type="text" class="form-control" placeholder="Zip / Postal code" />
                                    <span class="text-danger small">{{ state.customerQuickErrors.zipCode }}</span>
                                </div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-md-12">
                                    <label>Country</label>
                                    <input v-model="state.customerQuickCountry" type="text" class="form-control" placeholder="Country (optional)" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card">
                        <div class="card-header"><h6 class="mb-0"><i class="fas fa-phone me-2 text-primary"></i>Contact</h6></div>
                        <div class="card-body">
                            <div class="row mb-2">
                                <div class="col-md-6">
                                    <label>Phone Number <span class="text-danger">*</span></label>
                                    <input v-model="state.customerQuickPhoneNumber" type="text" class="form-control" placeholder="Phone number" />
                                    <span class="text-danger small">{{ state.customerQuickErrors.phoneNumber }}</span>
                                </div>
                                <div class="col-md-6">
                                    <label>Email Address <span class="text-danger">*</span></label>
                                    <input v-model="state.customerQuickEmailAddress" type="email" class="form-control" placeholder="Email address" />
                                    <span class="text-danger small">{{ state.customerQuickErrors.emailAddress }}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" v-on:click="handler.closeCustomerQuickCreate"><i class="fas fa-times me-1"></i>Cancel</button>
                    <button type="button" class="btn btn-primary" v-on:click="handler.submitCustomerQuickCreate" v-bind:disabled="state.customerQuickIsSubmitting">
                        <span class="spinner-border spinner-border-sm me-1" v-if="state.customerQuickIsSubmitting"></span>
                        <i class="fas fa-user-plus me-1" v-else></i>
                        {{ state.customerQuickIsSubmitting ? 'Creating...' : 'Create & Select' }}
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- CustomerGroup Quick Create Modal -->
    <div class="modal fade" ref="customerGroupQuickModalRef" id="CustomerGroupQuickModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-md">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="fas fa-users me-2"></i>Quick Create Customer Group</h5>
                    <button type="button" class="btn-close btn-close-white" v-on:click="handler.closeCustomerGroupQuickCreate" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3"><i class="fas fa-info-circle me-1"></i>Fill in the required fields. The new group will be automatically selected after creation.</p>
                    <div class="row mb-2">
                        <div class="col-md-12">
                            <label>Name <span class="text-danger">*</span></label>
                            <input v-model="state.customerGroupQuickName" type="text" class="form-control" placeholder="Customer group name" />
                            <span class="text-danger small">{{ state.customerGroupQuickErrors.name }}</span>
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-12">
                            <label>Description</label>
                            <textarea v-model="state.customerGroupQuickDescription" class="form-control" rows="2" placeholder="Optional"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" v-on:click="handler.closeCustomerGroupQuickCreate"><i class="fas fa-times me-1"></i>Cancel</button>
                    <button type="button" class="btn btn-success" v-on:click="handler.submitCustomerGroupQuickCreate" v-bind:disabled="state.customerGroupQuickIsSubmitting">
                        <span class="spinner-border spinner-border-sm me-1" v-if="state.customerGroupQuickIsSubmitting"></span>
                        <i class="fas fa-users me-1" v-else></i>
                        {{ state.customerGroupQuickIsSubmitting ? 'Creating...' : 'Create & Select' }}
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- CustomerCategory Quick Create Modal -->
    <div class="modal fade" ref="customerCategoryQuickModalRef" id="CustomerCategoryQuickModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-md">
            <div class="modal-content">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title"><i class="fas fa-tag me-2"></i>Quick Create Customer Category</h5>
                    <button type="button" class="btn-close" v-on:click="handler.closeCustomerCategoryQuickCreate" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3"><i class="fas fa-info-circle me-1"></i>Fill in the required fields. The new category will be automatically selected after creation.</p>
                    <div class="row mb-2">
                        <div class="col-md-12">
                            <label>Name <span class="text-danger">*</span></label>
                            <input v-model="state.customerCategoryQuickName" type="text" class="form-control" placeholder="Customer category name" />
                            <span class="text-danger small">{{ state.customerCategoryQuickErrors.name }}</span>
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-12">
                            <label>Description</label>
                            <textarea v-model="state.customerCategoryQuickDescription" class="form-control" rows="2" placeholder="Optional"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" v-on:click="handler.closeCustomerCategoryQuickCreate"><i class="fas fa-times me-1"></i>Cancel</button>
                    <button type="button" class="btn btn-warning text-dark" v-on:click="handler.submitCustomerCategoryQuickCreate" v-bind:disabled="state.customerCategoryQuickIsSubmitting">
                        <span class="spinner-border spinner-border-sm me-1" v-if="state.customerCategoryQuickIsSubmitting"></span>
                        <i class="fas fa-tag me-1" v-else></i>
                        {{ state.customerCategoryQuickIsSubmitting ? 'Creating...' : 'Create & Select' }}
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/FrontEnd/Pages/SalesOrders/SalesOrderList.cshtml.js"></script>
}