@page
@{
    ViewData["Title"] = "Warranty Check";
}

<div id="app" v-cloak>
    <div class="row mb-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5><i class="fas fa-shield-alt me-2 text-primary"></i>Warranty Check</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label>Customer</label>
                            <div ref="customerIdRef"></div>
                        </div>
                        <div class="col-md-4">
                            <label>Product</label>
                            <div ref="productIdRef"></div>
                        </div>
                        <div class="col-md-2">
                            <label>Claim Date <span class="text-danger">*</span></label>
                            <input ref="claimDateRef">
                        </div>
                        <div class="col-md-2 d-flex gap-2">
                            <button type="button"
                                    class="btn btn-primary w-100"
                                    v-on:click="handler.search"
                                    v-bind:disabled="state.isSearching">
                                <span class="spinner-border spinner-border-sm me-1" v-if="state.isSearching"></span>
                                <i class="fas fa-search me-1" v-else></i>
                                {{ state.isSearching ? 'Searching...' : 'Search' }}
                            </button>
                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    v-on:click="handler.reset"
                                    title="Reset filters">
                                <i class="fas fa-undo"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="grid-container">
                <div ref="mainGridRef" id="MainGrid"></div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/FrontEnd/Pages/Warranties/WarrantyCheck.cshtml.js"></script>
}
