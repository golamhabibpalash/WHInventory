@page
@{
    ViewData["Title"] = "Sign In";
}

<div id="app" v-cloak>

    <div class="auth-form-title">
        <h2>Welcome back</h2>
        <p>Sign in to your uStock account to continue</p>
    </div>

    <form v-on:submit.prevent="handleSubmit" novalidate>

        <div class="auth-field">
            <label for="Email">Email Address</label>
            <div class="auth-input-group">
                <i class="fas fa-envelope a-icon"></i>
                <input id="Email"
                       name="Email"
                       type="email"
                       placeholder="name@company.com"
                       v-model="state.email"
                       v-on:input="state.errors.email = ''"
                       autocomplete="email">
            </div>
            <span v-if="state.errors.email" class="auth-field-error">{{ state.errors.email }}</span>
        </div>

        <div class="auth-field">
            <label for="Password">Password</label>
            <div class="auth-input-group">
                <i class="fas fa-lock a-icon"></i>
                <input id="Password"
                       name="Password"
                       :type="state.showPassword ? 'text' : 'password'"
                       placeholder="Enter your password"
                       v-model="state.password"
                       v-on:input="state.errors.password = ''"
                       autocomplete="current-password">
                <button type="button"
                        class="auth-pw-toggle"
                        v-on:click="state.showPassword = !state.showPassword"
                        tabindex="-1"
                        aria-label="Toggle password visibility">
                    <i :class="state.showPassword ? 'fas fa-eye-slash' : 'fas fa-eye'"></i>
                </button>
            </div>
            <span v-if="state.errors.password" class="auth-field-error">{{ state.errors.password }}</span>
        </div>

        <div class="auth-options-row">
            <label class="auth-remember">
                <input type="checkbox" v-model="state.rememberMe">
                Remember me
            </label>
            <a asp-page="/Accounts/ForgotPassword" class="auth-link">Forgot password?</a>
        </div>

        <button type="submit" class="auth-btn" v-bind:disabled="state.isSubmitting">
            <span class="spinner-border spinner-border-sm"
                  v-if="state.isSubmitting"
                  role="status"
                  aria-hidden="true"></span>
            <i v-if="!state.isSubmitting" class="fas fa-sign-in-alt"></i>
            {{ state.isSubmitting ? 'Signing in...' : 'Sign In' }}
        </button>

    </form>

    <p class="auth-bottom-link">
        Don't have an account? <a asp-page="/Accounts/Register">Create one</a>
    </p>

</div>

@section scripts {
    <script type="module" src="~/FrontEnd/Pages/Accounts/Login.cshtml.js"></script>
}
