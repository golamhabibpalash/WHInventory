@page
@{
    ViewData["Title"] = "Reset Password";
}
<div class="container-fluid" id="app" v-cloak>

    <div class="card-body register-card-body">
        <p class="login-box-msg">@ViewData["Title"]</p>
        <div class="row">
            <div class="col-md-12 text-center mb-3">
                <h3 class="text-dark">Set New Password</h3>
                <a asp-page="/Index" class="">
                    <p><i class="fas fa-home me-2 text-warning"></i><span class="text-dark">uStock</span></p>
                </a>
            </div>
            <div class="col-md-12">
                <div class="mb-3">
                    <label>New Password</label>
                    <input v-model="state.newPassword" type="password" class="form-control" placeholder="Enter new password" />
                    <span class="text-danger small">{{ state.errors.newPassword }}</span>
                </div>
                <div class="mb-3">
                    <label>Confirm Password</label>
                    <input v-model="state.confirmPassword" type="password" class="form-control" placeholder="Confirm new password" />
                    <span class="text-danger small">{{ state.errors.confirmPassword }}</span>
                </div>
                <button type="button"
                        class="btn btn-primary w-100"
                        v-on:click="handler.submit"
                        v-bind:disabled="state.isSubmitting">
                    <span class="spinner-border spinner-border-sm me-2" v-if="state.isSubmitting"></span>
                    <i class="fas fa-key me-1" v-else></i>
                    {{ state.isSubmitting ? 'Resetting...' : 'Reset Password' }}
                </button>
            </div>
        </div>
    </div>

</div>


@section scripts {
    <script src="~/FrontEnd/Pages/Accounts/ForgotPasswordConfirmation.cshtml.js"></script>
}
