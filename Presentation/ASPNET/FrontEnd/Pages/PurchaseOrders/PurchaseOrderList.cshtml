@page
@{
    ViewData["Title"] = "Purchase Order List";
}

<div id="app" v-cloak>
    <div class="row">
        <div class="col-12">
            <div class="grid-container">
                <div ref="mainGridRef" id="MainGrid"></div>
            </div>
        </div>
    </div>

    <div class="modal fade" ref="mainModalRef" id="MainModal" aria-hidden="true" tabindex="-1" data-bs-focus="false" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">{{ state.mainTitle }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" v-model="state.id" id="Id" name="Id" />
                    <form id="MainForm">
                        <div class="row">
                            <div class="col-md-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h5><i class="fas fa-info-circle me-2 text-primary"></i>Main Info</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row mb-2">
                                            <div class="col-md-6">
                                                <label for="OrderDate">Order Date</label>
                                                <input ref="orderDateRef" />
                                                <label class="text-danger">{{ state.errors.orderDate }}</label>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="Number">Number</label>
                                                <input ref="numberRef" v-model="state.number" readonly>
                                            </div>
                                        </div>
                                        <div class="row mb-2">
                                            <div class="col-md-6">
                                                <label for="VendorId">Vendor</label>
                                                <div class="d-flex align-items-center gap-2">
                                                    <div ref="vendorIdRef" class="flex-grow-1"></div>
                                                    <button type="button"
                                                            class="btn btn-sm btn-outline-success flex-shrink-0"
                                                            v-on:click="handler.openVendorQuickCreate"
                                                            v-bind:disabled="state.deleteMode"
                                                            title="Quick-create a new vendor">
                                                        <i class="fas fa-plus me-1"></i>New
                                                    </button>
                                                </div>
                                                <label class="text-danger">{{ state.errors.vendorId }}</label>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="TaxId">Tax</label>
                                                <div ref="taxIdRef"></div>
                                                <label class="text-danger">{{ state.errors.taxId }}</label>
                                            </div>
                                        </div>
                                        <div class="row mb-2">
                                            <div class="col-md-6">
                                                <label for="OrderStatus">Order Status</label>
                                                <div ref="orderStatusRef"></div>
                                                <label class="text-danger">{{ state.errors.orderStatus }}</label>
                                            </div>
                                        </div>
                                        <div class="row mb-2">
                                            <div class="col-md-12">
                                                <label for="Description">Description</label>
                                                <textarea class="form-control" rows="3" v-model="state.description"></textarea>
                                                <label class="text-danger">{{ state.errors.description }}</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                    <div id="ComplexDiv" :style="{ display: state.showComplexDiv ? 'block' : 'none' }">
                        <div class="row mt-3">
                            <div class="col-md-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h5><i class="fas fa-list-ul me-2 text-primary"></i>Purchase Order Item</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="grid-container">
                                                    <div ref="secondaryGridRef" id="SecondaryGrid"></div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row mt-4">
                            <div class="col-md-12">
                                <div class="card shadow-sm">
                                    <div class="card-header text-white">
                                        <h5 class="mb-0"><i class="fas fa-receipt me-2 text-success"></i>Payment Summary</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row justify-content-end">
                                            <div class="col-md-6">
                                                <div class="d-flex justify-content-between py-2 border-bottom">
                                                    <span class="fw-bold">Subtotal</span>
                                                    <span id="SubTotalAmount">{{ state.subTotalAmount }}</span>
                                                </div>
                                                <div class="d-flex justify-content-between py-2 border-bottom">
                                                    <span class="fw-bold">Tax</span>
                                                    <span id="TaxAmount">{{ state.taxAmount }}</span>
                                                </div>
                                                <div class="d-flex justify-content-between py-2">
                                                    <span class="fw-bold">Total Amount</span>
                                                    <span id="TotalAmount" class="fw-bold text-success">{{ state.totalAmount }}</span>
                                                </div>
                                                <div class="py-2 border-top mt-1" v-if="state.amountInWords">
                                                    <div class="text-muted small fw-bold">Amount in Words</div>
                                                    <div id="AmountInWords" class="fst-italic text-dark small">{{ state.amountInWords }}</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><i class="fas fa-times me-1"></i>Close</button>
                    <button type="button"
                            id="MainSaveButton"
                            class="btn"
                            v-if="!state.isNewlyCreated"
                            v-bind:class="state.deleteMode ? 'btn-danger' : 'btn-primary'"
                            v-on:click="handler.handleSubmit"
                            v-bind:disabled="state.isSubmitting">
                        <span class="spinner-border spinner-border-sm me-2" v-if="state.isSubmitting" role="status" aria-hidden="true"></span>
                        <i v-if="!state.isSubmitting" v-bind:class="state.deleteMode ? 'fas fa-trash me-1' : 'fas fa-save me-1'"></i><span v-if="!state.isSubmitting">{{ state.deleteMode ? 'Delete' : 'Save' }}</span>
                        <span v-else>{{ state.deleteMode ? 'Deleting...' : 'Saving...' }}</span>
                    </button>
                    <button type="button"
                            class="btn btn-success"
                            v-if="state.isNewlyCreated"
                            v-on:click="handler.handleSubmitClose">
                        <i class="fas fa-check me-1"></i>Submit
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Vendor Group Quick Create Modal -->
    <div class="modal fade" ref="vendorGroupQuickModalRef" id="VendorGroupQuickModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-md">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="fas fa-layer-group me-2"></i>Quick Create Vendor Group</h5>
                    <button type="button" class="btn-close btn-close-white" v-on:click="handler.closeVendorGroupQuickCreate" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3"><i class="fas fa-info-circle me-1"></i>Fill in the required fields. The new group will be automatically selected after creation.</p>
                    <div class="row mb-2">
                        <div class="col-md-12">
                            <label>Name <span class="text-danger">*</span></label>
                            <input v-model="state.vendorGroupQuickName" type="text" class="form-control" placeholder="Vendor group name" />
                            <span class="text-danger small">{{ state.vendorGroupQuickErrors.name }}</span>
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-12">
                            <label>Description</label>
                            <textarea v-model="state.vendorGroupQuickDescription" class="form-control" rows="2" placeholder="Optional"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" v-on:click="handler.closeVendorGroupQuickCreate"><i class="fas fa-times me-1"></i>Cancel</button>
                    <button type="button" class="btn btn-success" v-on:click="handler.submitVendorGroupQuickCreate" v-bind:disabled="state.vendorGroupQuickIsSubmitting">
                        <span class="spinner-border spinner-border-sm me-1" v-if="state.vendorGroupQuickIsSubmitting"></span>
                        <i class="fas fa-layer-group me-1" v-else></i>
                        {{ state.vendorGroupQuickIsSubmitting ? 'Creating...' : 'Create & Select' }}
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Vendor Category Quick Create Modal -->
    <div class="modal fade" ref="vendorCategoryQuickModalRef" id="VendorCategoryQuickModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-md">
            <div class="modal-content">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title"><i class="fas fa-tag me-2"></i>Quick Create Vendor Category</h5>
                    <button type="button" class="btn-close" v-on:click="handler.closeVendorCategoryQuickCreate" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3"><i class="fas fa-info-circle me-1"></i>Fill in the required fields. The new category will be automatically selected after creation.</p>
                    <div class="row mb-2">
                        <div class="col-md-12">
                            <label>Name <span class="text-danger">*</span></label>
                            <input v-model="state.vendorCategoryQuickName" type="text" class="form-control" placeholder="Vendor category name" />
                            <span class="text-danger small">{{ state.vendorCategoryQuickErrors.name }}</span>
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-12">
                            <label>Description</label>
                            <textarea v-model="state.vendorCategoryQuickDescription" class="form-control" rows="2" placeholder="Optional"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" v-on:click="handler.closeVendorCategoryQuickCreate"><i class="fas fa-times me-1"></i>Cancel</button>
                    <button type="button" class="btn btn-warning text-dark" v-on:click="handler.submitVendorCategoryQuickCreate" v-bind:disabled="state.vendorCategoryQuickIsSubmitting">
                        <span class="spinner-border spinner-border-sm me-1" v-if="state.vendorCategoryQuickIsSubmitting"></span>
                        <i class="fas fa-tag me-1" v-else></i>
                        {{ state.vendorCategoryQuickIsSubmitting ? 'Creating...' : 'Create & Select' }}
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Vendor Quick Create Modal -->
    <div class="modal fade" ref="vendorQuickModalRef" id="VendorQuickModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="fas fa-store me-2"></i>Quick Create Vendor</h5>
                    <button type="button" class="btn-close btn-close-white" v-on:click="handler.closeVendorQuickCreate" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3"><i class="fas fa-info-circle me-1"></i>Fill in the required fields. The new vendor will be automatically selected after creation.</p>
                    <div class="row mb-2">
                        <div class="col-md-8">
                            <label>Name <span class="text-danger">*</span></label>
                            <input v-model="state.vendorQuickName" type="text" class="form-control" placeholder="Vendor name" />
                            <span class="text-danger small">{{ state.vendorQuickErrors.name }}</span>
                        </div>
                        <div class="col-md-4">
                            <label>Country</label>
                            <input v-model="state.vendorQuickCountry" type="text" class="form-control" placeholder="Optional" />
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-6">
                            <label>Vendor Group <span class="text-danger">*</span></label>
                            <div class="d-flex align-items-center gap-2">
                                <div ref="vendorQuickGroupIdRef" class="flex-grow-1"></div>
                                <button type="button"
                                        class="btn btn-sm btn-outline-success flex-shrink-0"
                                        v-on:click="handler.openVendorGroupQuickCreate"
                                        title="Quick-create a new vendor group">
                                    <i class="fas fa-plus me-1"></i>New
                                </button>
                            </div>
                            <span class="text-danger small">{{ state.vendorQuickErrors.vendorGroupId }}</span>
                        </div>
                        <div class="col-md-6">
                            <label>Vendor Category <span class="text-danger">*</span></label>
                            <div class="d-flex align-items-center gap-2">
                                <div ref="vendorQuickCategoryIdRef" class="flex-grow-1"></div>
                                <button type="button"
                                        class="btn btn-sm btn-outline-warning flex-shrink-0"
                                        v-on:click="handler.openVendorCategoryQuickCreate"
                                        title="Quick-create a new vendor category">
                                    <i class="fas fa-plus me-1"></i>New
                                </button>
                            </div>
                            <span class="text-danger small">{{ state.vendorQuickErrors.vendorCategoryId }}</span>
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-6">
                            <label>Street <span class="text-danger">*</span></label>
                            <input v-model="state.vendorQuickStreet" type="text" class="form-control" />
                            <span class="text-danger small">{{ state.vendorQuickErrors.street }}</span>
                        </div>
                        <div class="col-md-6">
                            <label>City <span class="text-danger">*</span></label>
                            <input v-model="state.vendorQuickCity" type="text" class="form-control" />
                            <span class="text-danger small">{{ state.vendorQuickErrors.city }}</span>
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-4">
                            <label>State <span class="text-danger">*</span></label>
                            <input v-model="state.vendorQuickState" type="text" class="form-control" />
                            <span class="text-danger small">{{ state.vendorQuickErrors.state }}</span>
                        </div>
                        <div class="col-md-4">
                            <label>Zip Code <span class="text-danger">*</span></label>
                            <input v-model="state.vendorQuickZipCode" type="text" class="form-control" />
                            <span class="text-danger small">{{ state.vendorQuickErrors.zipCode }}</span>
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-6">
                            <label>Phone Number <span class="text-danger">*</span></label>
                            <input v-model="state.vendorQuickPhoneNumber" type="text" class="form-control" />
                            <span class="text-danger small">{{ state.vendorQuickErrors.phoneNumber }}</span>
                        </div>
                        <div class="col-md-6">
                            <label>Email Address <span class="text-danger">*</span></label>
                            <input v-model="state.vendorQuickEmailAddress" type="email" class="form-control" />
                            <span class="text-danger small">{{ state.vendorQuickErrors.emailAddress }}</span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" v-on:click="handler.closeVendorQuickCreate">
                        <i class="fas fa-times me-1"></i>Cancel
                    </button>
                    <button type="button" class="btn btn-success"
                            v-on:click="handler.submitVendorQuickCreate"
                            v-bind:disabled="state.vendorQuickIsSubmitting">
                        <span class="spinner-border spinner-border-sm me-1" v-if="state.vendorQuickIsSubmitting"></span>
                        <i class="fas fa-store me-1" v-else></i>
                        {{ state.vendorQuickIsSubmitting ? 'Creating...' : 'Create & Select' }}
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/FrontEnd/Pages/PurchaseOrders/PurchaseOrderList.cshtml.js"></script>
}