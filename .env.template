# ── Database ─────────────────────────────────────────────────────────────────
# These values are used by both the postgres container and the app container.
DB_NAME=ustock
DB_USER=ustock_user
DB_PASSWORD=CHANGE_ME_strong_password_here

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Get this token from: Cloudflare Zero Trust → Networks → Tunnels → your tunnel → Configure → Token
CLOUDFLARE_TUNNEL_TOKEN=PASTE_YOUR_TUNNEL_TOKEN_HERE
